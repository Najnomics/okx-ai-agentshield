{
  "name": "agentshield-payment-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Onchain OS reverse-proxy sidecar that adds x402 pay-per-call charging in front of the AgentShield FastAPI service.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/proxy.js",
    "start:env-proxy": "node --use-env-proxy dist/proxy.js",
    "dev": "tsx proxy.ts",
    "dev:env-proxy": "node --use-env-proxy --import tsx proxy.ts"
  },
  "dependencies": {
    "@okxweb3/x402-core": "^0.1.0",
    "@okxweb3/x402-evm": "^0.2.1",
    "@okxweb3/x402-express": "^0.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
